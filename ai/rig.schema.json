{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sirdizarm.github.io/BoltWorks3DAIStudio/ai/rig.schema.json",
  "title": "BoltWorks Bone Rig",
  "type": "object",
  "required": ["kind", "version", "coordinateSpace", "rotationUnit", "ground", "bones"],
  "properties": {
    "kind": { "const": "boltworks-rig" },
    "version": { "const": 1 },
    "coordinateSpace": { "enum": ["world", "local"] },
    "rotationUnit": { "enum": ["radians", "degrees"] },
    "ground": {
      "type": "object",
      "required": ["axis", "value", "contactBoneIds"],
      "properties": {
        "axis": { "const": "y" },
        "value": { "const": 0 },
        "contactBoneIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "source": { "type": "object" },
    "bones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "parentId", "position", "rotation"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "parentId": { "type": ["string", "null"] },
          "position": {
            "type": "array",
            "prefixItems": [{ "type": "number" }, { "type": "number" }, { "type": "number" }],
            "minItems": 3,
            "maxItems": 3
          },
          "rotation": {
            "type": "array",
            "prefixItems": [{ "type": "number" }, { "type": "number" }, { "type": "number" }],
            "minItems": 3,
            "maxItems": 3
          },
          "role": { "type": "string" },
          "side": { "enum": ["center", "left", "right"] },
          "contact": { "type": "boolean" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": true
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
